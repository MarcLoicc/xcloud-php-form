---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import { Filter, Search, PlusCircle, MoreHorizontal, Download, ArrowUpDown, Zap, Leaf, Users } from '@lucide/astro';

const leads = [
  { id: 1, name: 'Marc Loi', company: 'Marcloi Enterprises', status: 'ganado', price: '12,500€', source: 'pago', date: '24 MAR' },
  { id: 2, name: 'Elena Rius', company: 'Digital Flux', status: 'enviar_propuesta', price: '4,200€', source: 'organico', date: '23 MAR' },
  { id: 3, name: 'Robert Fox', company: 'Fox Design', status: 'nuevo', price: '8,900€', source: 'pago', date: '22 MAR' },
  { id: 4, name: 'Sarah Wilson', company: 'Wilson Corp', status: 'no_responde', price: '3,000€', source: 'organico', date: '21 MAR' },
  { id: 5, name: 'John Doe', company: 'Doe Tech', status: 'no_cualificado', price: '1,500€', source: 'pago', date: '20 MAR' },
  { id: 6, name: 'Jane Smith', company: 'Jane Design', status: 'interesado_tarde', price: '0€', source: 'organico', date: '19 MAR' },
];

const statusStyles = {
  nuevo: 'bg-blue-100/50 text-blue-600 border-blue-200 shadow-blue-50',
  no_responde: 'bg-slate-100/50 text-slate-500 border-slate-200',
  llamar_tarde: 'bg-amber-100/50 text-amber-600 border-amber-200 shadow-amber-50',
  enviar_propuesta: 'bg-indigo-100/50 text-indigo-600 border-indigo-200 shadow-indigo-50',
  propuesta_enviada: 'bg-purple-100/50 text-purple-600 border-purple-200 shadow-purple-50',
  ganado: 'bg-emerald-100/50 text-emerald-600 border-emerald-200 shadow-emerald-50',
  perdido: 'bg-red-100/50 text-red-600 border-red-200 shadow-red-50',
  no_cualificado: 'bg-zinc-100/50 text-zinc-400 border-zinc-200',
  interesado_tarde: 'bg-cyan-100/50 text-cyan-600 border-cyan-200 shadow-cyan-50',
};

const statusLabels = {
  nuevo: 'Nuevo Lead',
  no_responde: 'No Responde',
  llamar_tarde: 'Llamar Tarde',
  enviar_propuesta: 'Enviar Propuesta',
  propuesta_enviada: 'Prop. Enviada',
  ganado: 'Ganado',
  perdido: 'Perdido',
  no_cualificado: 'No Cualificado',
  interesado_tarde: 'Interesado +',
};
---

<Layout title="Gestión de Leads - CRM Premium">
	<Sidebar />
	
	<main class="sm:ml-72 min-h-screen p-8 lg:p-12 space-y-10">
		<header class="flex flex-col md:flex-row md:items-end justify-between gap-10">
			<div>
				<div class="flex items-center gap-3 mb-4">
					<Users class="w-8 h-8 text-indigo-600 stroke-[2.5]" />
					<h1 class="text-4xl font-black text-slate-800 tracking-tighter italic">Gestión de <span class="text-indigo-600 not-italic">Leads</span></h1>
				</div>
				<p class="text-slate-500 font-medium max-w-sm">Optimiza tu embudo de ventas y mantén el control de tus prospectos de alto valor.</p>
			</div>
			
			<div class="flex gap-4">
				<button class="px-6 py-4 bg-white border border-slate-200 rounded-3xl text-xs font-black text-slate-400 hover:text-slate-900 transition-all shadow-xl shadow-slate-100 flex items-center gap-2 group">
					<Download class="w-4 h-4 group-hover:translate-y-0.5 transition-all" /> EXPORTAR
				</button>
				<button class="px-10 py-4 bg-indigo-600 rounded-3xl text-sm font-black text-white hover:bg-slate-900 transition-all shadow-2xl shadow-indigo-100 flex items-center gap-3 active:scale-95">
					<PlusCircle class="w-5 h-5" /> NUEVO REGISTRO
				</button>
			</div>
		</header>

		<!-- Tool Bar -->
		<section class="flex flex-col lg:flex-row items-center justify-between gap-6 p-6 bg-white/40 border border-white/60 rounded-[3rem] backdrop-blur-3xl shadow-2xl shadow-slate-100">
			<div class="flex items-center gap-3 w-full lg:w-auto">
				<div class="relative w-full lg:w-80 group">
					<Search class="w-5 h-5 absolute left-5 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-indigo-600 transition-all" />
					<input type="text" placeholder="Búsqueda estratégica..." class="w-full pl-14 pr-6 py-4 bg-white/50 border border-slate-100 rounded-2xl focus:ring-4 focus:ring-indigo-100 focus:border-indigo-600 outline-none transition-all text-sm font-bold text-slate-800 placeholder-slate-400 shadow-sm" />
				</div>
				<button class="p-4 bg-slate-900 text-white rounded-2xl shadow-lg hover:bg-black transition-all active:scale-95">
					<Filter class="w-5 h-5" />
				</button>
			</div>

			<div class="flex items-center gap-4 overflow-x-auto pb-2 lg:pb-0 scrollbar-none">
				<button class="px-5 py-2.5 bg-indigo-600 text-white rounded-2xl text-[10px] font-black uppercase tracking-widest shadow-[0_5px_15px_-5px_#4f46e5]">Todos</button>
				<button class="px-5 py-2.5 bg-white border border-slate-100 text-slate-400 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:border-slate-800 transition-all">Nuevos</button>
				<button class="px-5 py-2.5 bg-white border border-slate-100 text-slate-400 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:border-slate-800 transition-all">Propuestas</button>
				<button class="px-5 py-2.5 bg-emerald-50 border border-emerald-100 text-emerald-600 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-emerald-600 hover:text-white transition-all">Ganados</button>
			</div>
		</section>

		<!-- Premium Table -->
		<div class="relative bg-white/50 border border-white/60 rounded-[3.5rem] backdrop-blur-3xl shadow-2xl shadow-slate-200 overflow-hidden group">
			<table class="w-full text-left border-collapse">
				<thead>
					<tr class="bg-indigo-50/30 text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">
						<th class="px-10 py-6">Lead / Organización <ArrowUpDown class="inline w-3 h-3 ml-2 opacity-50" /></th>
						<th class="px-6 py-6 text-center">Estado Flujo</th>
						<th class="px-6 py-6 text-center">Origen <ArrowUpDown class="inline w-3 h-3 ml-2 opacity-50" /></th>
						<th class="px-6 py-6 text-right">Inversión</th>
						<th class="px-10 py-6 text-right">Acciones</th>
					</tr>
				</thead>
				<tbody class="divide-y divide-white/50">
					{leads.map((lead) => (
						<tr class="group/row hover:bg-white transition-all cursor-pointer">
							<td class="px-10 py-8">
								<div class="flex items-center gap-5">
									<div class="w-14 h-14 bg-indigo-50 rounded-2xl border-2 border-white flex items-center justify-center text-indigo-600 font-black text-lg shadow-sm group-hover/row:scale-110 transition-all">
										{lead.name.charAt(0)}
									</div>
									<div class="flex flex-col">
										<span class="text-lg font-black text-slate-800 group-hover/row:text-indigo-600 transition-all tracking-tight leading-none italic">{lead.name}</span>
										<div class="flex items-center gap-2 mt-2">
											<span class="text-[11px] font-bold text-slate-400 uppercase tracking-widest">{lead.company}</span>
											<span class="w-1 h-1 bg-slate-200 rounded-full"></span>
											<span class="text-[10px] font-black text-indigo-400 tabular-nums">{lead.date}</span>
										</div>
									</div>
								</div>
							</td>
							<td class="px-6 py-8 text-center">
								<span class={`px-4 py-2 rounded-2xl border text-[9px] font-black uppercase tracking-widest shadow-sm shadow-slate-100 ${statusStyles[lead.status]}`}>
									{statusLabels[lead.status]}
								</span>
							</td>
							<td class="px-6 py-8 text-center">
								<div class="flex items-center justify-center gap-2">
									{lead.source === 'pago' ? (
										<Zap class="w-4 h-4 text-amber-500 fill-amber-500/20" />
									) : (
										<Leaf class="w-4 h-4 text-indigo-400" />
									)}
									<span class={`text-[10px] font-black uppercase tracking-[0.2em] ${lead.source === 'pago' ? 'text-amber-500' : 'text-indigo-400'}`}>
										{lead.source === 'pago' ? 'PAID ADS' : 'ORGANIC'}
									</span>
								</div>
							</td>
							<td class="px-6 py-8 text-right">
								<span class="text-2xl font-black text-slate-800 tracking-tighter tabular-nums italic group-hover/row:text-indigo-600 transition-all">{lead.price}</span>
							</td>
							<td class="px-10 py-8 text-right">
								<button class="p-3 bg-slate-50 hover:bg-indigo-600 hover:text-white rounded-2xl transition-all shadow-sm group-hover/row:shadow-lg group-hover/row:shadow-indigo-100">
									<MoreHorizontal class="w-6 h-6" />
								</button>
							</td>
						</tr>
					))}
				</tbody>
			</table>
      
      {/* Table Footer / Pagination */}
      <div class="p-8 bg-white/30 flex justify-between items-center">
        <span class="text-[11px] font-bold text-slate-400 uppercase tracking-widest italic">Mostrando <span class="text-slate-900 font-black">6</span> prospectos de alto valor</span>
        <div class="flex gap-2">
          <button class="px-4 py-2 bg-white border border-slate-100 rounded-xl text-[10px] font-black text-slate-400 hover:border-slate-800 transition-all">Prev</button>
          <button class="px-4 py-2 bg-slate-900 border border-slate-800 text-[10px] font-black text-white rounded-xl">Next</button>
        </div>
      </div>
		</div>
	</main>
</Layout>

<style>
	table {
		border-spacing: 0;
	}
	.scrollbar-none::-webkit-scrollbar {
		display: none;
	}
	.scrollbar-none {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
</style>
