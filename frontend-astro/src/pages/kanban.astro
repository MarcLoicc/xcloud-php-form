---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import { Plus, MoreHorizontal, MessageSquare, Paperclip, Zap, Building2, UserCircle2 } from '@lucide/astro';

const columns = [
  { id: 'nuevo', name: 'Nuevos', count: 3, color: 'blue' },
  { id: 'enviar_propuesta', name: 'Enviar Prop.', count: 2, color: 'indigo' },
  { id: 'propuesta_enviada', name: 'Presentados', count: 4, color: 'purple' },
  { id: 'ganado', name: 'Éxitos', count: 12, color: 'emerald' },
];

const cards = [
  { id: 1, column: 'nuevo', name: 'Marc Loi', company: 'Marcloi Ent.', price: '12,500€', priority: 'high', tags: ['Ads'], source: 'pago' },
  { id: 2, column: 'nuevo', name: 'Sarah Wilson', company: 'Wilson Corp', price: '3,000€', priority: 'medium', tags: ['B2B'], source: 'organico' },
  { id: 3, column: 'enviar_propuesta', name: 'Elena Rius', company: 'Digital Flux', price: '4,200€', priority: 'high', tags: ['Web'], source: 'organico' },
  { id: 4, column: 'ganado', name: 'John Doe', company: 'Tech Hub', price: '25,000€', priority: 'high', tags: ['Full Stack'], source: 'pago' },
];
---

<Layout title="Flujo Kanban - CRM Premium">
	<Sidebar />
	
	<main class="sm:ml-72 min-h-screen p-8 lg:p-12 flex flex-col">
		<header class="flex flex-col md:flex-row md:items-center justify-between gap-8 mb-12">
			<div>
				<h1 class="text-4xl font-black text-slate-800 tracking-tighter italic">Ventas <span class="text-indigo-600 not-italic">En Flujo</span></h1>
				<p class="text-slate-500 font-medium mt-2">Visualiza y gestiona el progreso de tus oportunidades comerciales.</p>
			</div>
			<div class="flex gap-4">
        <div class="flex items-center -space-x-4">
          {[1,2,3,4].map(i => (
            <div class="w-10 h-10 rounded-full border-4 border-white overflow-hidden shadow-xl ring-2 ring-indigo-50">
              <img src={`https://api.dicebear.com/7.x/avataaars/svg?seed=User${i}`} class="w-full h-full object-cover" />
            </div>
          ))}
          <button class="w-10 h-10 rounded-full bg-slate-100 border-4 border-white flex items-center justify-center text-[10px] font-black text-slate-400 hover:bg-indigo-600 hover:text-white transition-all shadow-md">
            +12
          </button>
        </div>
				<button class="px-8 py-4 bg-indigo-600 rounded-3xl text-sm font-black text-white hover:bg-black transition-all shadow-2xl shadow-indigo-100 flex items-center gap-3 active:scale-95">
					<Plus class="w-5 h-5" /> REGLA DE AUTOMACIÓN
				</button>
			</div>
		</header>

		<!-- Kanban Board -->
		<section class="flex-1 -mx-4 overflow-x-auto pb-4 scrollbar-thin scrollbar-thumb-indigo-200">
			<div class="flex gap-8 px-4 h-full min-w-[1200px]">
				{columns.map((col) => (
					<div class="flex-1 flex flex-col min-w-[320px] max-w-[400px]">
						<!-- Column Header -->
						<div class="flex items-center justify-between mb-6 px-2">
							<div class="flex items-center gap-3">
								<div class={`w-3 h-3 rounded-full bg-${col.color}-500 shadow-lg shadow-${col.color}-200`}></div>
								<h3 class="text-[13px] font-black text-slate-700 uppercase tracking-widest leading-none bg-white p-2.5 rounded-2xl shadow-sm border border-slate-100">{col.name}</h3>
								<span class="text-[11px] font-black text-slate-400 bg-slate-200/50 px-2 py-0.5 rounded-lg tabular-nums">{col.count}</span>
							</div>
							<button class="p-2 text-slate-400 hover:text-indigo-600 transition-colors">
								<MoreHorizontal class="w-5 h-5" />
							</button>
						</div>

						<!-- Cards Container -->
						<div class="flex-1 space-y-6 p-4 bg-white/30 border border-white/50 rounded-[4rem] backdrop-blur-3xl shadow-inner overflow-y-auto max-h-[calc(100vh-320px)] scrollbar-none group/col">
							{cards.filter(c => c.column === col.id).map((card) => (
								<div draggable="true" class="group relative bg-white border border-white p-7 rounded-[2.5rem] shadow-xl shadow-slate-200/50 hover:shadow-2xl hover:shadow-indigo-100/50 transition-all hover:-translate-y-2 cursor-grab active:cursor-grabbing overflow-hidden">
                  <div class={`absolute top-0 right-10 w-12 h-1 bg-${col.color}-500 rounded-b-full`}></div>
                  
                  <div class="flex items-center justify-between mb-6">
                    <div class="flex items-center gap-2">
                      <div class="w-10 h-10 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600 shadow-sm border border-white group-hover:scale-110 transition-all">
                        <UserCircle2 class="w-6 h-6" />
                      </div>
                      <span class="text-[11px] font-black text-slate-400 uppercase tracking-widest">{card.company}</span>
                    </div>
                    {card.source === 'pago' && <Zap class="w-4 h-4 text-amber-500 fill-amber-500/10" />}
                  </div>

									<h4 class="text-xl font-black text-slate-800 tracking-tight italic mb-2 group-hover:text-indigo-600 transition-colors uppercase">{card.name}</h4>
									<p class="text-[28px] font-black text-slate-800 tracking-tighter tabular-nums mb-6 italic">{card.price}</p>
									
									<div class="flex flex-wrap gap-2 mb-8">
										{card.tags.map(tag => (
											<span class="px-3 py-1 bg-slate-50 border border-slate-100 text-[9px] font-black text-slate-400 uppercase tracking-widest rounded-lg">#{tag}</span>
										))}
									</div>

									<div class="flex items-center justify-between pt-6 border-t border-slate-50">
										<div class="flex items-center gap-4 text-slate-400">
											<div class="flex items-center gap-1.5 group-hover:text-indigo-400 transition-colors">
												<MessageSquare class="w-4 h-4" />
												<span class="text-[10px] font-black">2</span>
											</div>
											<div class="flex items-center gap-1.5 group-hover:text-amber-400 transition-colors">
												<Paperclip class="w-4 h-4" />
												<span class="text-[10px] font-black">1</span>
											</div>
										</div>
                    <div class="w-8 h-8 rounded-full border-2 border-white overflow-hidden shadow-sm group-hover:ring-4 group-hover:ring-indigo-50 transition-all">
                      <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Marc" />
                    </div>
									</div>
								</div>
							))}

              {/* Add Card Skeleton */}
              <button class="w-full py-8 border-2 border-dashed border-slate-200 text-slate-300 rounded-[2.5rem] flex flex-col items-center gap-2 hover:border-indigo-400 hover:text-indigo-600 hover:bg-indigo-50/50 transition-all group/add">
                <Plus class="w-8 h-8 group-hover/add:rotate-90 transition-all" />
                <span class="text-[10px] font-black uppercase tracking-[0.4em]">Soltar o Añadir</span>
              </button>
						</div>
					</div>
				))}
			</div>
		</section>
	</main>
</Layout>

<style>
	.scrollbar-thin::-webkit-scrollbar {
		height: 6px;
	}
	.scrollbar-thin::-webkit-scrollbar-thumb {
		background-color: rgb(224 231 255);
		border-radius: 20px;
	}
</style>
